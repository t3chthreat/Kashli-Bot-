# Kalshi credentials (generate at kalshi.com → Settings → API)
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY=

# Risk limits
MAX_POSITION_USD=25
MAX_EXPOSURE_USD=200
DAILY_LOSS_LIMIT_USD=50
MIN_EDGE=0.05
MAX_OPEN_POSITIONS=5

# Operation
SCAN_INTERVAL_SECS=30
DRY_RUN=true
LOG_LEVEL=INFO

# AWS (optional - enables S3 backup)
S3_BACKUP_BUCKET=
